{
    "name":  "@lupaflow/providers",
    "version":  "0.1.0",
    "type":  "module",
    "main":  "./dist/index.js",
    "module":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "require":  "./dist/index.js",
                              "import":  "./dist/index.js"
                          }
                },
    "scripts":  {
                    "build":  "tsup",
                    "dev":  "tsup --watch"
                },
    "dependencies":  {
                         "@lupaflow/core":  "workspace:*",
                         "@lupaflow/secrets":  "workspace:*",
                         "@lupaflow/types":  "workspace:*",
                         "openai":  "^4.68.0",
                         "@google/generative-ai":  "^0.21.0"
                     },
    "devDependencies":  {
                            "tsup":  "^8.3.0",
                            "typescript":  "^5.6.0"
                        }
}
