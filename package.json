{
  "name": "lupaflow",
  "version": "0.1.0",
  "private": true,
  "description": "AI Agent Framework — build, run, and orchestrate intelligent agents",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:types && bun run build:core && bun run build:plugins && bun run build:secrets && bun run build:providers && bun run build:tools && bun run build:memory && bun run build:agent && bun run build:observability && bun run build:workflow && bun run build:multi-agent && bun run build:cli",
    "build:types": "bun run --filter '@lupaflow/types' build",
    "build:core": "bun run --filter '@lupaflow/core' build",
    "build:plugins": "bun run --filter '@lupaflow/plugins' build",
    "build:secrets": "bun run --filter '@lupaflow/secrets' build",
    "build:providers": "bun run --filter '@lupaflow/providers' build",
    "build:tools": "bun run --filter '@lupaflow/tools' build",
    "build:memory": "bun run --filter '@lupaflow/memory' build",
    "build:observability": "bun run --filter '@lupaflow/observability' build",
    "build:agent": "bun run --filter '@lupaflow/agent' build",
    "build:workflow": "bun run --filter '@lupaflow/workflow' build",
    "build:multi-agent": "bun run --filter '@lupaflow/multi-agent' build",
    "build:cli": "bun run --filter '@lupaflow/cli' build",
    "dev": "bun run --filter './packages/*' dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.11.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "files": [],
  "bin": null,
  "main": null
}
